# 拼拼看Me - 环境配置
DATABASE_URL=sqlite:///./puzzle_fusion.db

# JWT 密钥 —— 生产环境必须修改！
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# 环境: development / staging / production
ENVIRONMENT=development

# 安全：是否允许 X-User-Id header 旁路认证（仅开发环境）
ALLOW_USER_ID_HEADER=true

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=puzzle_fragments

# Embedding 模型（支持 OpenAI / DeepSeek 等兼容 API）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# Sentry DSN（可选，置空则不启用）
# SENTRY_DSN=https://your-dsn@sentry.io/project
SENTRY_ENVIRONMENT=development

# Rate Limiting 存储后端（memory:// 或 redis://localhost:6379）
RATE_LIMIT_STORAGE=memory://

# ---------- SMTP 邮件 ----------
# SMTP 服务器配置（开发环境不配则仅日志输出）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@puzzlefusion.app

# ---------- Web Push ----------
VAPID_PRIVATE_KEY_PATH=keys/vapid_private.pem
VAPID_PUBLIC_KEY_PATH=keys/vapid_public.pem
VAPID_SUBJECT=mailto:admin@puzzlefusion.me
PUSH_ENABLED=true

# AI 外部 API（不配则纯用内置规则引擎，不影响使用）
# 支持任何 OpenAI-compatible API：DeepSeek / OpenAI / SiliconFlow 等
# AI_API_KEY=sk-你的密钥
# AI_API_BASE=https://api.deepseek.com
# AI_MODEL=deepseek-chat
