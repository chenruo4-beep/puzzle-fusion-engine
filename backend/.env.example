# 拼拼看Me - 后端环境配置
# 复制为 .env 并修改

# 数据库连接
# 开发环境（SQLite）：
DATABASE_URL=sqlite:///./data/puzzle_fusion.db
# 生产环境（PostgreSQL）：
# DATABASE_URL=postgresql://user:password@host:5432/puzzle_fusion

# JWT 密钥（生产环境必须修改为随机字符串！）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ---------- 向量数据库（仅外部 AI 模式需要）----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=puzzle_fragments

# Embedding 模型
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# AI 外部 API（用于 embedding + LLM 推理）
# 支持任何 OpenAI-compatible API：OpenAI / DeepSeek / SiliconFlow 等
# AI_API_KEY=sk-你的密钥
# AI_API_BASE=https://api.openai.com

# 日志级别（DEBUG / INFO / WARNING / ERROR）
# LOG_LEVEL=INFO

# Sentry DSN（可选，生产环境推荐）
# SENTRY_DSN=https://your-dsn@sentry.io/project
# SENTRY_ENVIRONMENT=production

# ---------- Web Push ----------
# VAPID 密钥对路径（首次启动时自动生成）
# VAPID_PRIVATE_KEY_PATH=keys/vapid_private.pem
# VAPID_PUBLIC_KEY_PATH=keys/vapid_public.pem
# VAPID_SUBJECT=mailto:admin@puzzlefusion.me
# PUSH_ENABLED=true

# Stripe 支付
# 从 https://dashboard.stripe.com/apikeys 获取
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
# Webhook 签名密钥：在 Stripe Dashboard > Webhooks 创建端点后获取
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
# 定价 ID：在 Stripe Dashboard > Products 创建后获取
# STRIPE_PRICE_MONTHLY=price_monthly_xxxx
# STRIPE_PRICE_YEARLY=price_yearly_xxxx
