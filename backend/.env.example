# 拼图融合引擎 - 环境配置示例
# 复制此文件为 .env 并修改配置

# 数据库连接（开发环境使用 SQLite）
DATABASE_URL=sqlite:///./puzzle_fusion.db
# DATABASE_URL=postgresql://user:password@localhost:5432/puzzle_fusion

# JWT 密钥（生产环境必须修改！）
SECRET_KEY=dev-secret-key-change-in-production

# 向量数据库（Qdrant）
QDRANT_URL=http://localhost:6333

# AI 服务配置（可选，使用 QClaw 作为 AI 后端）
QCLOUD_API_KEY=
QCLOUD_API_BASE=
